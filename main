local Rayfield

local s,e = pcall(function()
   Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
end)

if not s then
   warn("Failed to load IceDude Exploits")
   return
else
   print("Success! IceDude Exploits loading")
end

local Window = Rayfield:CreateWindow({
   Name = "IceDude exploits",
   Icon = 0, -- Icon in Topbar. Can use Lucide Icons (string) or Roblox Image (number). 0 to use no icon (default).
   LoadingTitle = "Rayfield Interface Suite",
   LoadingSubtitle = "by Sirius",
   ShowText = "Rayfield", -- for mobile users to unhide Rayfield, change if you'd like
   Theme = "Default", -- Check https://docs.sirius.menu/rayfield/configuration/themes

   ToggleUIKeybind = "K", -- The keybind to toggle the UI visibility (string like "K" or Enum.KeyCode)

   DisableRayfieldPrompts = false,
   DisableBuildWarnings = false, -- Prevents Rayfield from emitting warnings when the script has a version mismatch with the interface.

   -- ScriptID = "sid_xxxxf34xxxxxxxx", -- Your Script ID from developer.sirius.menu — enables analytics, managed keys, and script hosting

   ConfigurationSaving = {
      Enabled = true,
      FolderName = nil, -- Create a custom folder for your hub/game
      FileName = "Big Hub"
   },
  
   KeySystem = false, -- Set this to true to use our key system
})

local esp = loadstring(game:HttpGet("https://raw.githubusercontent.com/1C3DUD3/IceDude-Hub/refs/heads/main/esp"))()
local util = loadstring(game:HttpGet("https://raw.githubusercontent.com/1C3DUD3/IceDude-Hub/refs/heads/main/utility"))()

local storedAssets={
   esp={}
}

local connections={}

local espActivated={
   Universal={
      Player={Enabled=false,Color=Color3.fromRGB(255,255,255)}
   },
   Forsaken = {
      Survivor={Enabled=false,Color=Color3.fromRGB(0,255,0), Asset = workspace.Players.Survivors},
      Killer = {Enabled=false,Color = Colof3.fromRGB(255,0,0), Asset = workspace.Players.Killers}
   }
}

local values={
HumSpeed = -1,
HumJP = -1
}

local self=game.Players.LocalPlayer





-- UNIVERSAL

local v0 = Window:CreateTab("Universal", 4483362458)

v0:CreateSection("Humanoid")

v0:CreateInput({
   Name = "WalkSpeed (-1 to disable)",
   CurrentValue = "-1",
   PlaceholderText = "Input Placeholder",
   RemoveTextAfterFocusLost = false,
   Flag = "ws",
   Callback = function(Text)
       values.HumSpeed = tonumber(Text)
   end,
})

if self.Character.Humanoid.UseJumpPower then
v0:CreateInput({
   Name = "JumpPower (-1 to disable)",
   CurrentValue = "-1",
   PlaceholderText = "Input Placeholder",
   RemoveTextAfterFocusLost = false,
   Flag = "jp",
   Callback = function(Text)
       values.HumJP = tonumber(Text)
   end,
})
else
v0:CreateInput({
   Name = "JumpHeight (-1 to disable)",
   CurrentValue = "-1",
   PlaceholderText = "Input Placeholder",
   RemoveTextAfterFocusLost = false,
   Flag = "jh",
   Callback = function(Text)
       values.HumJP = tonumber(Text)
   end,
})
end

v0:CreateSection("ESP")

v0:CreateColorPicker({
    Name = "Player ESP Color",
    Color = Color3.fromRGB(255,255,255),
    Flag = "espr",
    Callback = function(Value)
       espActivated.Universal.Player.Color=Value
    end
})

v0:CreateToggle({
   Name = "Player ESP",
   CurrentValue = false,
   Flag = "ToggleESP",
   Callback = function(Value)
      espActivated.Universal.Player.Enabled=Value
   end,
})

v0:CreateSection("Misc.")

v0:CreateInput({
   Name = "Gravity (-1 to disable)",
   CurrentValue = "-1",
   PlaceholderText = "Input Placeholder",
   RemoveTextAfterFocusLost = false,
   Flag = "InputGravity",
   Callback = function(Text)
       if tonumber(Text) ~= -1 then
           workspace.Gravity = tonumber(Text)
       else
           workspace.Gravity = 196.2
       end
   end,
})

v0:CreateButton({
   Name = "Remove IceDude Exploits",
   Callback = function()
       for _,v in pairs(connections) do
          v:Disconnect()
          v = nil
       end

       for i,v in pairs(storedAssets) do
          if typeof(v) == "table" then
             for i2,v2 in pairs(v) do
                v2:Destroy()
                v[i2]=nil
             end
          else
              v:Destroy()
              storedAssets[i]=nil
          end
       end
       Rayfield:Destroy()
   end,
})


-- FORSAKEN

local v1 = Window:CreateTab("Forsaken", 4483362458)

v1:CreateColorPicker({
    Name = "Survivor ESP Color",
    Color = Color3.fromRGB(0,255,0),
    Flag = "v1-surv",
    Callback = function(Value)
       espActivated.Forsaken.Survivor.Color=Value
    end
})

v1:CreateToggle({
   Name = "Survivor ESP",
   CurrentValue = false,
   Flag = "v1-survE",
   Callback = function(Value)
      espActivated.Forsaken.Survivor.Enabled=Value
   end,
})

v1:CreateColorPicker({
    Name = "Killer ESP Color",
    Color = Color3.fromRGB(255,0,0),
    Flag = "v1-killer",
    Callback = function(Value)
       espActivated.Forsaken.Killer.Color=Value
    end
})

v1:CreateToggle({
   Name = "Killer ESP",
   CurrentValue = false,
   Flag = "v1-killerE",
   Callback = function(Value)
      espActivated.Forsaken.Killer.Enabled=Value
   end,
})

connections.FrameCheck = game.RunService.RenderStepped:Connect(function()
    if espActivated.Universal.Player.Enabled == true then
       for _,v in pairs(game.Players:GetPlayers()) do
          if v~=self then
             storedAssets.esp[v] = esp.esp(v.Character,espActivated.Universal.Player.Color,util.plrFullName(v).." | "..math.round(util.distance(self.Character,v.Character)).."m")
          end
       end
    else
        for player, espObj in pairs(storedAssets.esp) do
          espObj:Destroy()
          storedAssets.esp[player] = nil
        end
    end

    if typeof(tonumber(values.HumSpeed)) == "number" and values.HumSpeed ~= -1 then
      self.Character.Humanoid.WalkSpeed = tonumber(values.HumSpeed)
    else
      self.Character.Humanoid.WalkSpeed = 16
   end

    if typeof(tonumber(values.HumJP)) == "number" and values.HumJP ~= -1 then
       if self.Character.Humanoid.UseJumpPower then
          self.Character.Humanoid.JumpPower = tonumber(values.HumJP)
      else
          self.Character.Humanoid.JumpHeight = tonumber(values.HumJP)
      end
    end

   -- GAME SPECIFIC ESP

   if espActivated.Forsaken.Survivor.Enabled == true then
       for _,v in pairs(workspace.Players.Survivors:GetChildren()) do
          if v~=self.Character then
             storedAssets.esp[v] = esp.esp(v,espActivated.Forsaken.Survivor.Color,util.plrFullName(game.Players:GetPlayerFromCharacter(v)).." ["..v.Name.."] | "..math.round(util.distance(self.Character,v)).."m")
          end
       end
   end

   if espActivated.Forsaken.Killer.Enabled == true then
       for _,v in pairs(workspace.Players.Killers:GetChildren()) do
          if v~=self.Character then
             storedAssets.esp[v] = esp.esp(v,espActivated.Forsaken.Killer.Color,util.plrFullName(game.Players:GetPlayerFromCharacter(v)).." ["..v.Name.."] | "..math.round(util.distance(self.Character,v)).."m")
          end
       end
   end
end)
